# ─────────────────────────────────────────────────────────────────────────────
# Streamlit Secrets Yapılandırması
# ─────────────────────────────────────────────────────────────────────────────
# 
# LOKAL KULLANIM:
# 1. Bu dosyayı "secrets.toml" olarak kopyalayın (aynı klasörde)
# 2. Değerleri doldurun
# 3. .gitignore'da secrets.toml'un olduğundan emin olun
#
# STREAMLIT CLOUD KULLANIMI:
# 1. Streamlit Cloud dashboard'unda uygulamanızı açın
# 2. Sağ üstteki "⋮" (3 nokta) → Settings → Secrets
# 3. Aşağıdaki içeriği kopyalayıp yapıştırın ve değerleri doldurun
# 4. "Save" butonuna tıklayın
#
# NOT: Google Cloud Console'da API key'inizin "Application restrictions" 
# ayarına *.streamlit.app domain'ini eklemeyi unutmayın!
# ─────────────────────────────────────────────────────────────────────────────

GOOGLE_MAPS_API_KEY = "AIzaSy..."
APP_PASSWORD = "guclu_bir_sifre"
